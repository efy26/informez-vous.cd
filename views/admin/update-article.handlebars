<div class="article-container-admin">
    <section class="article-header-admin">
        <div class="article-content-admin">
            <h2>Modifier l'article</h2>
            <p>Vous pouvez modifier cet article.</p>
        </div>
    </section>

    <section class="article-formulaire-admin">
        <form action="/admin/planifier" class="article-form-admin" method="POST" novalidate>
            <div class="article-formulaire-container-admin">
                <div class="form-group-titre">
                    <label for="titre">Titre de l'article</label>
                    <input type="text" id="titre" name="titre" value="{{ article.title}}" required>
                </div>
                <div class="form-group-categorie-image">
                    <div class="select-categorie">
                        <label for="categorie">Catégorie</label>
                        <select id="categorie" name="categorie" required>
                            <option value="">Sélectionnez une catégorie</option>

                        </select>
                    </div>
                             <div class="select-categorie">
                        <label for="categorie">Sous-catégorie</label>
                        <select id="categorie" name="categorie"  required>
                            <option value="">Sélectionnez une sous-catégorie</option>
     

                        </select>
                    </div>
                    <div class="televerser-image">
                        <label for="image">Téléverser une nouvelle image si vous voulez la modifier (.png, .webp, .jpeg)</label>
                        <input type="file" id="image" name="image" accept="image/*" >
                    </div>
                </div>

                <div class="contenue-article">
                     <label for="contenu">Contenu de l'article</label>

                    <textarea
                        id="contenu"
                        name="contenu"
                        rows="10"
                        required>
                        {{article.content}}
                    </textarea>
                </div>
            </div>

            <div class="option-publication">
                <h3>Options de publication</h3>
                <div class="sommaire">
                    <label for="sommaire">Sommaire de l'article</label>
                    <textarea id="sommaire" name="sommaire" rows="10" maxlength="282">{{ article.summary}}</textarea>
                </div>
                <div class="status">
                    <label for="status">Statut de l'article</label>
                    <select id="status" name="status" required>
                        <option value="">Sélectionnez le statut de votre article</option>

                    </select>
                </div>
                <div class="planifier">
                    <label for="planification">Planification de la publication</label>
                    <input type="datetime-local" id="planification" name="planification" value="{{article.planifier_date}}" disabled required>
                </div>
                
                </div>
                <div class="btn-article-update-admin">
                <button type="submit">Modifier l'article</button>
                <label for=""></label>
                </div>
            </div>

            
        </form>
    </section>

</div>
