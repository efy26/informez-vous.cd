<div class="apercu-article-container-amin">
  <section class="apercu-article-content-admin">
    <div class="apercu-article-content-categorie-admin">
      <p><strong>{{categoriecase}} </strong>- {{subCategorie.slug}}</p>
    </div>
    <div class="apercu-article-content-titre-admin">
      <h1>
        {{article.title}}
      </h1>
    </div>
    <div class="apercu-article-content-img-auteur-date-admin">
      <div class="apercu-article-content-auteur-date">
        <div class="apercu-article-content-auteur">
          <p> <span>Publié le </span></p>
        </div>
        <i></i>
        <div class="apercu-article-content-date">
          <p>{{article.created_at}}</p>
        </div>
        {{!-- <i></i> --}}
        {{!-- <div class="apercu-article-content-role">
          <p>{{auteur.role}}</p>
        </div> --}}
      </div>
      <div class="apercu-article-content-img">
        <img src="{{article.image}}" alt="Image d'un article" />

      </div>

      {{!-- <div class="share-buttons">
        <a
          target="_blank"
          href="https://www.facebook.com/sharer/sharer.php?u={{url}}"
        >
          Facebook
        </a>

        <a
          target="_blank"
          href="https://twitter.com/intent/tweet?url={{url}}&text={{article.title}}"
        >
          X (Twitter)
        </a>

        <a target="_blank" href="https://wa.me/?text={{article.title}} {{url}}">
          WhatsApp
        </a>
      </div> --}}

    </div>
    <div class="apercu-article-content-paragraphe-admin">

      <p>
        {{{article.content}}}
      </p>

    </div>
  </section>

  <section class="article-simulaire">
    <h2>Poursuivez votre lecture :</h2>
    <div class="sugestion-article">
        {{#each suggestions}}
        <a href="/lire-article?id={{id}}">
            <img src="{{image}}" alt="Image d'un article">
            <div class="sugestion-article-details">
                <h3>{{title}}</h3>
                <p>{{summary}}</p>
                <p>{{created_at}}</p>
            </div>
        
        </a>
        {{/each}}
    </div>
  </section>
</div>